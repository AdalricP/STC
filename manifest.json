{
  "manifest_version": 3,
  "name": "See thy commits",
  "version": "0.1.0",
  "description": "View a GitHub-style commit graph for public and private repositories directly on GitHub.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "See thy commits",
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/templates/commitItem.html",
        "src/templates/commitsContainer.html"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
